# --- App ---
APP_ENV=local
LOG_LEVEL=INFO

# --- Postgres (metadata) ---
PG_DSN=postgresql+asyncpg://extract:extract@postgres:5432/extract_meta

# --- Source DB (dev = mysql container, prod = SingleStore) ---
SOURCE_HOST=mysql
SOURCE_PORT=3306
SOURCE_USER=extract_ro
SOURCE_PASSWORD=extract_ro
SOURCE_DB=warehouse

# --- Redis (Arq broker) ---
REDIS_DSN=redis://redis:6379/0

# --- Storage ---
EXTRACT_DIR=/var/lib/extracts
DOWNLOAD_INTERNAL_PREFIX=/_internal/extracts

# --- Extract limits ---
EXTRACT_BATCH_SIZE=10000
EXTRACT_MAX_ROWS=50000000
EXTRACT_RETENTION_HOURS=72

# --- API key bootstrap (only used in local/dev; production issues via admin path) ---
BOOTSTRAP_API_KEY=ek_live_devtest_devtestdevtestdevtestdevtestde
